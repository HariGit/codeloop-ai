{
  "name": "codeloop-ai",
  "displayName": "CodeLoop AI",
  "description": "Local recursive coding agent for VS Code powered by Ollama (qwen3-coder)",
  "version": "0.1.0",
  "publisher": "vasu",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeloop-ai.startAgent",
        "title": "CodeLoop AI: Start Agent"
      },
      {
        "command": "codeloop-ai.explainApexClass",
        "title": "CodeLoop AI: Explain Apex Class"
      },
      {
        "command": "codeloop-ai.reviewApexClass",
        "title": "CodeLoop AI: Review Apex Class"
      },
      {
        "command": "codeloop-ai.createApexTest",
        "title": "CodeLoop AI: Create Apex Test Class"
      },
      {
        "command": "codeloop-ai.analyzeFlowMigration",
        "title": "CodeLoop AI: Analyze Flow Migration"
      },
      {
        "command": "codeloop-ai.deploymentReview",
        "title": "CodeLoop AI: Deployment Review"
      },
      {
        "command": "codeloop-ai.scanSalesforceProject",
        "title": "CodeLoop AI: Scan Salesforce Project"
      }
    ],
    "configuration": {
      "title": "CodeLoop AI",
      "properties": {
        "codeloopAi.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "anthropic",
            "openai",
            "vscode-lm"
          ],
          "default": "ollama",
          "description": "Model provider: ollama (local, default), anthropic (Claude), openai, or vscode-lm (VS Code Language Model API / Copilot)."
        },
        "codeloopAi.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (used when provider is 'anthropic')."
        },
        "codeloopAi.openAiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (used when provider is 'openai')."
        },
        "codeloopAi.apiKey": {
          "type": "string",
          "default": "",
          "description": "Fallback API key if a provider-specific key is not set."
        },
        "codeloopAi.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434/api/chat",
          "description": "Ollama chat API endpoint"
        },
        "codeloopAi.model": {
          "type": "string",
          "default": "qwen3-coder:latest",
          "description": "Ollama model name"
        },
        "codeloopAi.maxIterations": {
          "type": "number",
          "default": 8,
          "description": "Maximum agent loop iterations",
          "deprecationMessage": "Deprecated: use codeloopAi.loop.defaultMaxIterations instead."
        },
        "codeloopAi.loop.defaultMaxIterations": {
          "type": "number",
          "default": 8,
          "description": "Max iterations when the task mode has no specific limit."
        },
        "codeloopAi.loop.absoluteMaxIterations": {
          "type": "number",
          "default": 20,
          "description": "Hard ceiling on iterations \u2014 no mode may exceed this."
        },
        "codeloopAi.loop.jsonRetries": {
          "type": "number",
          "default": 2,
          "description": "Retries when the model returns invalid JSON."
        },
        "codeloopAi.loop.answerValidationRetries": {
          "type": "number",
          "default": 2,
          "description": "Retries when a final answer fails validation (empty or unverified claims)."
        },
        "codeloopAi.loop.noProgressLimit": {
          "type": "number",
          "default": 2,
          "description": "Stop after this many consecutive blocked/duplicate/no-op iterations."
        },
        "codeloopAi.loop.autoStopExplainAfterFiles": {
          "type": "boolean",
          "default": true,
          "description": "In EXPLAIN_APEX mode, push for the final answer once enough files are read."
        },
        "codeloopAi.loop.modeMaxIterations": {
          "type": "object",
          "default": {
            "EXPLAIN_APEX": 4,
            "REVIEW_APEX": 6,
            "MODIFY_APEX": 8,
            "CREATE_TEST": 10,
            "FLOW_MIGRATION": 8,
            "LWC_WORK": 8,
            "INTEGRATION_API": 8,
            "DEPLOYMENT_REVIEW": 6,
            "GENERAL_SALESFORCE": 6
          },
          "description": "Per-task-mode iteration limits (capped by absoluteMaxIterations)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
