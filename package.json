{
  "name": "codeloop-ai",
  "displayName": "CodeLoop AI",
  "description": "Local recursive coding agent for VS Code powered by Ollama (qwen3-coder)",
  "version": "0.1.0",
  "publisher": "vasu",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeloop-ai.startAgent",
        "title": "CodeLoop AI: Start Agent"
      },
      {
        "command": "codeloop-ai.explainApexClass",
        "title": "CodeLoop AI: Explain Apex Class"
      },
      {
        "command": "codeloop-ai.reviewApexClass",
        "title": "CodeLoop AI: Review Apex Class"
      },
      {
        "command": "codeloop-ai.createApexTest",
        "title": "CodeLoop AI: Create Apex Test Class"
      },
      {
        "command": "codeloop-ai.analyzeFlowMigration",
        "title": "CodeLoop AI: Analyze Flow Migration"
      },
      {
        "command": "codeloop-ai.deploymentReview",
        "title": "CodeLoop AI: Deployment Review"
      },
      {
        "command": "codeloop-ai.scanSalesforceProject",
        "title": "CodeLoop AI: Scan Salesforce Project"
      }
    ],
    "configuration": {
      "title": "CodeLoop AI",
      "properties": {
        "codeloopAi.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "anthropic",
            "openai",
            "vscode-lm"
          ],
          "default": "ollama",
          "description": "Model provider: ollama (local, default), anthropic (Claude), openai, or vscode-lm (VS Code Language Model API / Copilot)."
        },
        "codeloopAi.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (used when provider is 'anthropic')."
        },
        "codeloopAi.openAiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (used when provider is 'openai')."
        },
        "codeloopAi.apiKey": {
          "type": "string",
          "default": "",
          "description": "Fallback API key if a provider-specific key is not set."
        },
        "codeloopAi.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434/api/chat",
          "description": "Ollama chat API endpoint"
        },
        "codeloopAi.model": {
          "type": "string",
          "default": "qwen3-coder:latest",
          "description": "Ollama model name"
        },
        "codeloopAi.maxIterations": {
          "type": "number",
          "default": 8,
          "description": "Maximum agent loop iterations"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
